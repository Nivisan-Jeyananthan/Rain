{
    "app-id": "ch.nivisan.raincloud.network.client",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "23.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "rainchat",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=pulseaudio",
        "--socket=x11",
        "--socket=wayland",
        "--device=dri",
        "--env=GDK_SCALE=1",
        "--env=GDK_DPI_SCALE=1"
    ],
    "modules": [
        {
            "name": "openjdk",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/jdk",
                "tar --extract --gzip --no-same-owner --no-same-permissions -f *.tar.gz -C /app/jdk --strip-components=1"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://download.java.net/java/GA/jdk23.0.2/6da2a6609d6e406f85c491fcb119101b/7/GPL/openjdk-23.0.2_linux-x64_bin.tar.gz",
                    "sha256": "017f4ed8e8234d85e5bc1e490bb86f23599eadb6cfc9937ee87007b977a7d762"
                }
            ]
        },
        {
            "name": "rainchat",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/bin",
                "mkdir -p /app/share/applications",
                "mkdir -p /app/share/appdata",
                "mkdir -p /app/share/icons/hicolor/scalable/apps",
                "cp Client.jar /app/bin/",
                "cp ch.nivisan.raincloud.network.client.desktop /app/share/applications/",
                "cp ch.nivisan.raincloud.network.client.appdata.xml /app/share/appdata/",
                "cp ch.nivisan.raincloud.network.client.svg /app/share/icons/hicolor/scalable/apps/ch.nivisan.raincloud.network.client.svg",
                "echo '#!/bin/bash' > /app/bin/rainchat",
                "echo 'cd /app/bin' >> /app/bin/rainchat",
                "echo 'export GTK_IM_MODULE=ibus' >> /app/bin/rainchat",
                "echo 'exec /app/jdk/bin/java \\' >> /app/bin/rainchat",
                "echo '-Dawt.useSystemAAFontSettings=on \\' >> /app/bin/rainchat",
                "echo '-Dswing.aatext=true \\' >> /app/bin/rainchat",
                "echo '-Dswing.smoothFont=true \\' >> /app/bin/rainchat",
                "echo '-Dswing.useSystemFontSettings=true \\' >> /app/bin/rainchat",
                "echo '-Djdk.gtk.version=3 \\' >> /app/bin/rainchat",
                "echo '-Dsun.java2d.uiScale=1.0 \\' >> /app/bin/rainchat",
                "echo '-XX:+UseG1GC \\' >> /app/bin/rainchat",
                "echo '-XX:MaxGCPauseMillis=50 \\' >> /app/bin/rainchat",
                "echo '-XX:ParallelGCThreads=2 \\' >> /app/bin/rainchat",
                "echo '-XX:ConcGCThreads=1 \\' >> /app/bin/rainchat",
                "echo '-XX:+UnlockExperimentalVMOptions \\' >> /app/bin/rainchat",
                "echo '-XX:G1NewCollectionHeapPercent=20 \\' >> /app/bin/rainchat",
                "echo '-XX:G1MaxNewGenPercent=30 \\' >> /app/bin/rainchat",
                "echo '-XX:+ParallelRefProcEnabled \\' >> /app/bin/rainchat",
                "echo '-Dcom.sun.management.jmxremote=false \\' >> /app/bin/rainchat",
                "echo '-Dcom.sun.management.jmxremote.authenticate=false \\' >> /app/bin/rainchat",
                "echo '-Dsun.io.useFileChannelCache=false \\' >> /app/bin/rainchat",
                "echo '-jar Client.jar \"$@\"' >> /app/bin/rainchat",
                "chmod +x /app/bin/rainchat"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "Client.jar"
                },
                {
                    "type": "file",
                    "path": "ch.nivisan.raincloud.network.client.desktop"
                },
                {
                    "type": "file",
                    "path": "ch.nivisan.raincloud.network.client.appdata.xml"
                },
                {
                    "type": "file",
                    "path": "ch.nivisan.raincloud.network.client.svg"
                }
            ]
        }
    ]
}