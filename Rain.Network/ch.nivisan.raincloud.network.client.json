{
    "app-id": "ch.nivisan.raincloud.network.client",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "23.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "rainchat",
    "finish-args": [
        "--share=network",
        "--device=all",
        "--socket=pulseaudio",
        "--socket=x11",
        "--socket=wayland",
        "--filesystem=xdg-run/pulse:ro",
        "--talk-name=org.freedesktop.Notifications",
        "--env=DISPLAY=$DISPLAY",
        "--env=XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR",
        "--env=WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
    ],
    "modules": [
        {
            "name": "openjdk",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/jdk",
                "tar -xf *.tar.gz -C /app/jdk --strip-components=1"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://download.java.net/java/GA/jdk23.0.2/6da2a6609d6e406f85c491fcb119101b/7/GPL/openjdk-23.0.2_linux-x64_bin.tar.gz",
                    "sha256": "017f4ed8e8234d85e5bc1e490bb86f23599eadb6cfc9937ee87007b977a7d762"
                }
            ]
        },
        {
            "name": "rainchat",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/bin",
                "cp Client.jar /app/bin/",
                "echo '#!/bin/bash' > /app/bin/rainchat",
                "echo 'cd /app/bin' >> /app/bin/rainchat",
                "echo 'exec /app/jdk/bin/java -jar Client.jar' >> /app/bin/rainchat",
                "chmod +x /app/bin/rainchat"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "Client.jar"
                }
            ]
        }
    ]
}