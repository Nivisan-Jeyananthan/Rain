{
    "app-id": "ch.nivisan.raincloud.network.client",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "rainchat",
    "finish-args": [
        "--share=network",
        "--device=all",
        "--socket=pulseaudio",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=xdg-run/pulse:ro"
    ],
    "modules": [
        {
            "name": "openjdk",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/jdk",
                "tar -xf openjdk-25_linux-x64_bin.tar.gz -C /app/jdk --strip-components=1"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.java.net/java/GA/jdk25/bd75d5f9689641da8e1daabeccb5528b/36/GPL/openjdk-25_linux-x64_bin.tar.gz",
                    "sha256": "59cdcaf255add4721de38eb411d4ecfe779356b61fb671aee63c7dec78054c2b",
                    "dest": "openjdk-25_linux-x64_bin.tar.gz"
                }
            ]
        },
        {
            "name": "rainchat",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/bin",
                "cp Client.jar /app/bin/",
                "echo '#!/bin/bash' > /app/bin/rainchat",
                "echo 'cd /app/bin' >> /app/bin/rainchat",
                "echo 'exec /app/jdk/bin/java -jar Client.jar' >> /app/bin/rainchat",
                "chmod +x /app/bin/rainchat"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "Client.jar"
                }
            ]
        }
    ]
}