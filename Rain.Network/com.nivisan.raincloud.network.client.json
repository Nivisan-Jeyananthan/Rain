{
    "app-id": "ch.nivisan.raincloud.network.client",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "23.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "rainchat",
    "finish-args": [
        "--share=network",
        "--device=all",
        "--socket=pulseaudio",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=xdg-run/pulse:ro"
    ],
    "modules": [
        {
            "name": "openjdk",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/jdk",
                "tar -xf openjdk-21.tar.gz -C /app/jdk --strip-components=1"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.java.net/java/GA/jdk21.0.2/f2283984656d49d69e91c558476027ac/13/GPL/openjdk-21.0.2_linux-x64_bin.tar.gz",
                    "sha256": "a2ef86fb6c4bd62278e099d63b5c85b5ba1a5a8ea890d878c2a5a146a0c9c58a3b"
                }
            ]
        },
        {
            "name": "rainchat",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/bin",
                "cp Client.jar /app/bin/",
                "echo '#!/bin/bash' > /app/bin/rainchat",
                "echo 'cd /app/bin' >> /app/bin/rainchat",
                "echo 'exec /app/jdk/bin/java -jar Client.jar' >> /app/bin/rainchat",
                "chmod +x /app/bin/rainchat"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "Client.jar"
                }
            ]
        }
    ]
}